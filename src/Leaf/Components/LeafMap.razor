@using Leaf.Models
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JS

<div id="@_mapElementId" class="@CssClass" style="@Style"></div>

@code {
    private readonly string _mapElementId = $"leaf-map-{Guid.NewGuid():N}";
    private IJSObjectReference? _module;
    private IJSObjectReference? _instance;
    private bool _initialized;

    [Parameter] public LeafMapEngine Engine { get; set; } = LeafMapEngine.Leaflet;
    [Parameter] public double Latitude { get; set; } = 48.8566;
    [Parameter] public double Longitude { get; set; } = 2.3522;
    [Parameter] public double Zoom { get; set; } = 6;
    [Parameter] public IEnumerable<LeafMarker> Markers { get; set; } = Array.Empty<LeafMarker>();
    [Parameter] public bool EnableClustering { get; set; }
    [Parameter] public bool EnableDrawTool { get; set; }
    [Parameter] public string TileUrlTemplate { get; set; } = "https://tile.openstreetmap.org/{z}/{x}/{y}.png";
    [Parameter] public string MapStyleUrl { get; set; } = "https://demotiles.maplibre.org/style.json";
    [Parameter] public string CssClass { get; set; } = "leaf-map";
    [Parameter] public string Style { get; set; } = "height: 420px; width: 100%;";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/Leaf/leafMap.js");
            _instance = await _module.InvokeAsync<IJSObjectReference>("createLeafMap", _mapElementId, BuildOptions());
            _initialized = true;
            return;
        }

        if (_initialized && _instance is not null)
        {
            await _instance.InvokeVoidAsync("update", BuildOptions());
        }
    }

    private object BuildOptions() => new
    {
        engine = Engine.ToString().ToLowerInvariant(),
        latitude = Latitude,
        longitude = Longitude,
        zoom = Zoom,
        markers = Markers,
        enableClustering = EnableClustering,
        enableDrawTool = EnableDrawTool,
        tileUrlTemplate = TileUrlTemplate,
        mapStyleUrl = MapStyleUrl
    };

    public async ValueTask DisposeAsync()
    {
        if (_instance is not null)
        {
            await _instance.InvokeVoidAsync("dispose");
            await _instance.DisposeAsync();
        }

        if (_module is not null)
        {
            await _module.DisposeAsync();
        }
    }
}
