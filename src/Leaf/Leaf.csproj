<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>Leaf</PackageId>
    <Title>Leaf</Title>
    <Description>A clean Leaflet/MapLibre wrapper with markers, clustering, popups, and draw tool.</Description>
    <PackageTags>blazor;leaflet;maplibre;maps</PackageTags>
    <RepositoryUrl>https://github.com/agriffard/Leaf</RepositoryUrl>
    <PackageProjectUrl>https://github.com/agriffard/Leaf</PackageProjectUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="10.0.8" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
